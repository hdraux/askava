  "copyGuardrails": {
    "doNotClaim": [
      "that self-critique reliably exposes hidden errors",
      "that chain-of-thought reveals the model's true internal reasoning",
      "that known-answer tests calibrate overall reliability strongly",
      "that source verification guarantees detection of omissions or distortions",
      "that computational checks reliably redo every calculation correctly"
    ],
    "preferredFraming": [
      "can help identify",
      "can expose",
      "provides a limited signal",
      "supports inspection",
      "helps compare against"
    ]
