  "overrides": {
    "evidence": {
      "clear_source": {
        "prioritise": {
          "summarisation": ["source"],
          "content_generation": ["source"],
          "information_lookup": ["source"],
          "policy_interpretation": ["source"],
          "translation": ["source"]
        },
        "rules": [
          {
            "when": {
              "task": "summarisation",
              "level_gte": 2
            },
            "forceInclude": {
              "step3": ["source"]
            }
          },
          {
            "when": {
              "task": "policy_interpretation",
              "level_gte": 3
            },
            "forceInclude": {
              "step3": ["source"]
            }
          }
        ]
      },
      "partial_source": {
        "prioritise": {
          "summarisation": ["source"],
          "content_generation": ["source"],
          "information_lookup": ["source"],
          "policy_interpretation": ["source"]
        }
      },
      "no_source": {
        "remove": ["source"],
        "prioritise": {
          "content_generation": ["self-critique", "assumption", "known-answer"],
          "summarisation": ["self-critique", "variation"],
          "information_lookup": ["confidence", "known-answer", "variation"],
          "data_analysis": ["confidence", "assumption", "computational"],
          "policy_interpretation": ["confidence", "assumption", "rule"],
          "translation": ["self-critique", "variation", "known-answer"],
          "coding_assistance": ["self-critique", "assumption", "rule"],
          "other": ["self-critique", "assumption", "known-answer"]
        },
        "rules": [
          {
            "when": {
              "task_in": [
                "content_generation",
                "translation",
                "other"
              ]
            },
            "note": "Do not escalate just because no source exists if the task is generative by design."
          }
        ]
      }
    },
    "impact": {
      "high": {
        "rules": [
          {
            "when": {
              "level_gte": 2
            },
            "requireStep3": true
          },
          {
            "when": {
              "task": "data_analysis",
              "level_gte": 2
            },
            "forceInclude": {
              "step3": ["computational"]
            }
          },
          {
            "when": {
              "task": "policy_interpretation",
              "level_gte": 2
            },
            "forceInclude": {
              "step3": ["rule"]
            }
          },
          {
            "when": {
              "task": "summarisation",
              "evidence_in": ["clear_source", "partial_source"],
              "level_gte": 2
            },
            "forceInclude": {
              "step3": ["source"]
            }
          }
        ]
      }
    },
    "intended_use": {
      "external_or_operational": {
        "rules": [
          {
            "when": {
              "level_gte": 3
            },
            "requireStep3": true
          }
        ]
      },
      "regulatory_or_high_stakes": {
        "rules": [
          {
            "when": {},
            "setMinimumLevel": 4
          },
          {
            "when": {},
            "requireHumanReview": true
          },
          {
            "when": {},
            "note": "Prompt results are advisory only at this level."
          }
        ]
      }
    }
  },
  "selectionPolicy": {
    "uiMode": "one_per_step",
    "rules": [
      "For each populated step, show the first prompt as the default recommendation.",
      "If multiple prompts are listed for a step, treat later entries as alternates.",
      "If a forced prompt is added by override, move it to the front of that step.",
      "At level 4, display formal human review language regardless of prompt selection."
    ]
  },
  "defaultPromptChoice": {
    "content_generation": {
      "step1": "self-critique",
      "step2": "assumption",
      "step3": {
        "clear_source": "source",
        "partial_source": "source",
